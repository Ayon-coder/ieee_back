# Backend Environment Configuration (Example)
# Copy this to .env and fill in your actual values

# Firebase Configuration
# To get your Firebase token:
# 1. Go to Firebase Console > Project Settings > Service Accounts
# 2. Generate new private key (JSON)
# 3. Base64 encode the entire JSON and paste here
FIREBASE_TOKEN=ewogICJ0eXBlIjogInNlcnZpY2VfYWNjb3VudCIsCiAgIlByb2plY3RfaWQiOiAieW91ci1wcm9qZWN0LWlkIgp9Cg==

# Firebase Storage Bucket
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# Server Configuration
PORT=5001
NODE_ENV=development

# API URLs
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_FRONTEND_URL=http://localhost:5173
